# Copy to .env.test and point at a dedicated test database.
# NEVER point this at your development or production database —
# integration tests create and delete rows.

DATABASE_URL="postgresql://postgres:postgres123@localhost:5432/hotel_management_test"

JWT_ACCESS_SECRET=test-access-secret
JWT_REFRESH_SECRET=test-refresh-secret
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d
